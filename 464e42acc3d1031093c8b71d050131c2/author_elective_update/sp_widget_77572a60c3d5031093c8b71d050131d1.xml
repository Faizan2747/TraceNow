        <name>Copy of TraceNow Connection Form</name>
        <option_schema/>
        <public>false</public>
        <roles/>
        <script><![CDATA[(function() {
  if (input && input.action === 'test_connection') {
    var dm = new dm_test();
    dm.SOURCE_URL  = input.sourceUrl;
    dm.SOURCE_USER = input.username;
    dm.SOURCE_PSWD = input.password;
    // Attempt a lightweight fetch to verify credentials
    var test = dm.fetchSourceRecord('sys_db_object', 'task');
    data.success = (test !== null);
    data.message = test ? 'Connected' : 'Authentication failed. Check credentials.';
  }
})();]]></script>
