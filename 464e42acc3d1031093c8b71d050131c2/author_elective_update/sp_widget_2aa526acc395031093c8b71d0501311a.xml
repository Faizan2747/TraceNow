<?xml version="1.0" encoding="UTF-8"?><record_update table="sp_widget">
    <sp_widget action="DELETE">
        <category>custom</category>
        <client_script><![CDATA[api.controller=function($scope, spUtil) {
  var c = this;
  c.data.connected = false;
  
  c.connect = function() {
    c.server.get({
      action: 'test_connection',
      sourceUrl: c.data.sourceUrl,
      username: c.data.username,
      password: c.data.password
    }).then(function(response) {
      if (response.data.success) {
        c.data.connected = true;
        $scope.$emit('connection_established', c.data);
      } else {
        c.data.error = true;
        c.data.errorMsg = response.data.message;
      }
    });
  };
}]]></client_script>
        <controller_as>c</controller_as>
        <css/>
        <data_table>sp_instance</data_table>
