        <template><![CDATA[<div class="tracenow-connection">
  <h2>Connect to Source Instance</h2>
  <div class="form-group">
    <label>Source Instance URL</label>
    <input type="text" ng-model="c.data.sourceUrl" placeholder="https://yourinstance.service-now.com" class="form-control"/>
  </div>
  <div class="form-group">
    <label>Username</label>
    <input type="text" ng-model="c.data.username" class="form-control"/>
  </div>
  <div class="form-group">
    <label>Password</label>
    <input type="password" ng-model="c.data.password" class="form-control"/>
  </div>
  <div class="form-group">
    <label>Instance Name</label>
    <input type="text" ng-model="c.data.instanceName" class="form-control"/>
  </div>
  <button ng-click="c.connect()" class="btn btn-primary">Connect</button>
  
  <!-- Connection Status Indicator -->
  <span ng-if="c.data.connected" class="label label-success">● Connected</span>
  <span ng-if="c.data.error" class="label label-danger">● {{c.data.errorMsg}}</span>
</div>]]></template>
