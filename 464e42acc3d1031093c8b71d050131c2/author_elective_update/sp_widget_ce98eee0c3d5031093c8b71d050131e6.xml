<?xml version="1.0" encoding="UTF-8"?><record_update table="sp_widget">
    <sp_widget action="DELETE">
        <category>custom</category>
        <client_script><![CDATA[api.controller=function($scope) {
  var c = this;
  c.data.records = [];
  c.data.migrating = false;
  c.data.progress = 0;
  
  $scope.$on('table_selected', function(event, payload) {
    c.data.selectedTable = payload.table;
    c.data.connection    = payload.connection;
    c.server.get({ action: 'get_records', table: payload.table, connection: payload.connection })
      .then(function(r) { c.data.records = r.data.records; });
  });
  
  c.selectAll = function($event) {
    var checked = $event.target.checked;
    c.data.records.forEach(function(r) { r.selected = checked; });
  };
  
  c.getSelected = function() {
    return c.data.records.filter(function(r) { return r.selected; });
  };
  
  c.migrateNow = function() {
    var selected = c.getSelected();
    if (!selected.length) { alert('Please select at least one record.'); return; }
    c.data.migrating = true;
    c.data.progress  = 0;
    c.data.status    = 'Starting migration...';
    var sysIds = selected.map(function(r) { return r.sys_id; });
    c.server.get({
      action:     'migrate_now',
      table:      c.data.selectedTable,
      sysIds:     sysIds,
      connection: c.data.connection
    }).then(function(r) {
      c.data.progress  = 100;
      c.data.status    = 'Migration complete. Success: ' + r.data.success + ', Failed: ' + r.data.failed;
      c.data.migrating = false;
    });
  };
  
  c.addToQueue = function() {
    var selected = c.getSelected();
    if (!selected.length) { alert('Please select records first.'); return; }
    var sysIds = selected.map(function(r) { return r.sys_id; });
    c.server.get({ action: 'add_to_queue', table: c.data.selectedTable, sysIds: sysIds })
      .then(function(r) { alert(r.data.added + ' record(s) added to queue.'); });
  };
  
  c.removeSelection = function() {
    c.data.records.forEach(function(r) { r.selected = false; });
  };
}]]></client_script>
