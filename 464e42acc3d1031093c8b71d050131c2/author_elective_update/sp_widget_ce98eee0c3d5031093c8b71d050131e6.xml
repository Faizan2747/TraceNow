        <script><![CDATA[(function() {
  var dm = new dm_test();
  var conn = input && input.connection;
  if (conn) {
    dm.SOURCE_URL  = conn.sourceUrl;
    dm.SOURCE_USER = conn.username;
    dm.SOURCE_PSWD = conn.password;
  }
  
  if (input.action === 'get_records') {
    var api = new sn_ws.RESTMessageV2();
    api.setEndpoint(conn.sourceUrl + '/api/now/table/' + input.table +
      '?sysparm_limit=100&sysparm_display_value=false&sysparm_fields=sys_id,number,short_description,state');
    api.setHttpMethod('GET');
    api.setBasicAuth(conn.username, conn.password);
    var resp = api.execute();
    data.records = resp.getStatusCode() == 200 ? JSON.parse(resp.getBody()).result : [];
  }
  
  if (input.action === 'migrate_now') {
    var results = dm.migrateRecords(conn.sourceUrl, conn.username, conn.password, input.table, input.sysIds);
    data.success = results.success;
    data.failed  = results.failed;
  }
  
  if (input.action === 'add_to_queue') {
    var added = dm.queueMigration(input.table, input.sysIds);
    data.added = added;
  }
})();]]></script>
