  <div ng-if="!c.data.records.length">
    <p class="text-muted">No records loaded. Select a table first.</p>
  </div>
  <table class="table table-bordered table-hover" ng-if="c.data.records.length">
    <thead>
      <tr>
        <th><input type="checkbox" ng-click="c.selectAll($event)"/></th>
        <th>Number</th>
        <th>Short Description</th>
        <th>State</th>
        <th>Sys ID</th>
      </tr>
    </thead>
    <tbody>
      <tr ng-repeat="rec in c.data.records">
        <td><input type="checkbox" ng-model="rec.selected"/></td>
        <td>{{rec.number}}</td>
        <td>{{rec.short_description}}</td>
        <td>{{rec.state}}</td>
        <td>{{rec.sys_id}}</td>
      </tr>
    </tbody>
  </table>
  
  <!-- Action Buttons -->
  <div class="btn-group" ng-if="c.data.records.length">
    <button class="btn btn-success" ng-click="c.migrateNow()">Migrate Now</button>
    <button class="btn btn-info"    ng-click="c.addToQueue()">Add to Queue</button>
    <button class="btn btn-default" ng-click="c.removeSelection()">Remove Selection</button>
  </div>
  
  <!-- Live Progress Bar (shown during migration) -->
  <div ng-if="c.data.migrating" style="margin-top:15px;">
    <p><strong>Live Migration Activity</strong></p>
    <div class="progress">
      <div class="progress-bar" style="width: {{c.data.progress}}%">{{c.data.progress}}%</div>
    </div>
    <p>{{c.data.status}}</p>
  </div>
</div>]]></template>
