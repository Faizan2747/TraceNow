        <name>TraceNow Queue</name>
        <option_schema/>
        <public>false</public>
        <roles/>
        <script><![CDATA[(function() {
  var dm = new dm_test();
  
  if (input.action === 'get_queue_status') {
    data.stats = dm.getQueueStatus();
  }
  
  if (input.action === 'start_migration') {
    var conn = input.connection;
    data.result = dm.processMigrationQueue(conn.sourceUrl, conn.username, conn.password, 50);
  }
})();]]></script>
