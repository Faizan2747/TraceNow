<?xml version="1.0" encoding="UTF-8"?><record_update table="sp_widget">
    <sp_widget action="DELETE">
        <category>custom</category>
        <client_script><![CDATA[api.controller=function() {
  var c = this;
  c.server.get({ action: 'get_queue_status' }).then(function(r) {
    c.data.stats = r.data.stats;
  });
  
  c.startMigration = function() {
    c.server.get({ action: 'start_migration', connection: c.data.connection })
      .then(function(r) { c.data.result = r.data.result; });
  };
}]]></client_script>
