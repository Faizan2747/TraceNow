        <template><![CDATA[<div class="tracenow-queue">
  <h3>Migration Queue</h3>
  <div class="row">
    <div class="col-xs-3">
      <div class="panel panel-default text-center">
        <div class="panel-body">
          <h2>{{c.data.stats.pending}}</h2>
          <p>Pending</p>
        </div>
      </div>
    </div>
    <div class="col-xs-3">
      <div class="panel panel-default text-center">
        <div class="panel-body">
          <h2>{{c.data.stats.done}}</h2>
          <p>Done</p>
        </div>
      </div>
    </div>
    <div class="col-xs-3">
      <div class="panel panel-success text-center">
        <div class="panel-body">
          <h2>{{c.data.stats.running}}</h2>
          <p>Running</p>
        </div>
      </div>
    </div>
    <div class="col-xs-3">
      <div class="panel panel-danger text-center">
        <div class="panel-body">
          <h2>{{c.data.stats.failed}}</h2>
          <p>Failed</p>
        </div>
      </div>
    </div>
  </div>
  
  <button class="btn btn-primary btn-lg" ng-click="c.startMigration()">
    Start Migration
  </button>
  <p ng-if="c.data.result" style="margin-top:10px;">
    ✅ Batch complete — Success: {{c.data.result.success}}, Failed: {{c.data.result.failed}}
  </p>
</div>]]></template>
