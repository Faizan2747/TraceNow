        <template><![CDATA[<div class="tracenow-tables">
  <h3>Browse Tables</h3>
  <div ng-if="!c.data.connection">
    <p class="text-muted">Please connect to a source instance first.</p>
  </div>
  <div ng-if="c.data.connection">
    <input type="text" ng-model="c.tableSearch" placeholder="Search tables..." class="form-control"/>
    <ul class="list-group" style="margin-top:10px; max-height:400px; overflow-y:auto;">
      <li class="list-group-item"
          ng-repeat="table in c.data.tables | filter:c.tableSearch"
          ng-click="c.selectTable(table)"
          ng-class="{active: c.data.selectedTable == table.name}">
        {{table.label}} <small class="text-muted">({{table.name}})</small>
      </li>
    </ul>
  </div>
</div>]]></template>
