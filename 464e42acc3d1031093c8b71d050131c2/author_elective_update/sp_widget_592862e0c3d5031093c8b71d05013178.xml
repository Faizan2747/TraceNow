        <name>TraceNow Browse Tables</name>
        <option_schema/>
        <public>false</public>
        <roles/>
        <script><![CDATA[(function() {
  if (input && input.action === 'get_tables') {
    var conn = input.connection;
    var dm = new dm_test();
    dm.SOURCE_URL  = conn.sourceUrl;
    dm.SOURCE_USER = conn.username;
    dm.SOURCE_PSWD = conn.password;
    // Fetch available tables from source
    var api = new sn_ws.RESTMessageV2();
    api.setEndpoint(conn.sourceUrl + '/api/now/table/sys_db_object?sysparm_fields=name,label&sysparm_query=super_class.name=task^ORname=incident^ORname=problem^ORname=change_request&sysparm_limit=100&sysparm_display_value=false');
    api.setHttpMethod('GET');
    api.setBasicAuth(conn.username, conn.password);
    var resp = api.execute();
    if (resp.getStatusCode() == 200) {
      data.tables = JSON.parse(resp.getBody()).result || [];
    } else {
      data.tables = [];
    }
  }
})();]]></script>
