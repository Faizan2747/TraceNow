<?xml version="1.0" encoding="UTF-8"?><record_update table="sp_widget">
    <sp_widget action="DELETE">
        <category>custom</category>
        <client_script><![CDATA[api.controller=function($scope) {
  var c = this;
  
  $scope.$on('connection_established', function(event, connData) {
    c.data.connection = connData;
    c.server.get({ action: 'get_tables', connection: connData })
      .then(function(r) { c.data.tables = r.data.tables; });
  });
  
  c.selectTable = function(table) {
    c.data.selectedTable = table.name;
    $scope.$emit('table_selected', { table: table.name, connection: c.data.connection });
  };
}]]></client_script>
        <controller_as>c</controller_as>
